#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int val;
    int idx;
} Node;

void merge(Node arr[], int temp[], int result[], int left, int mid, int right) {
    int i = left;
    int j = mid + 1;
    int k = left;

    int rightCount = 0;

    while (i <= mid && j <= right) {
        if (arr[j].val < arr[i].val) {
            temp[k++] = j;
            rightCount++;
            j++;
        } else {
            result[arr[i].idx] += rightCount;
            temp[k++] = i;
            i++;
        }
    }

    while (i <= mid) {
        result[arr[i].idx] += rightCount;
        temp[k++] = i;
        i++;
    }

    while (j <= right) {
        temp[k++] = j;
        j++;
    }

    for (i = left; i <= right; i++) {
        arr[i] = arr[temp[i]];
    }
}

void mergeSort(Node arr[], int temp[], int result[], int left, int right) {
    if (left >= right) return;

    int mid = (left + right) / 2;

    mergeSort(arr, temp, result, left, mid);
    mergeSort(arr, temp, result, mid + 1, right);

    merge(arr, temp, result, left, mid, right);
}

void countSmaller(int nums[], int n, int result[]) {
    Node *arr = (Node*)malloc(n * sizeof(Node));
    int *temp = (int*)malloc(n * sizeof(int));

    for (int i = 0; i < n; i++) {
        arr[i].val = nums[i];
        arr[i].idx = i;
        result[i] = 0;
    }

    mergeSort(arr, temp, result, 0, n - 1);

    free(arr);
    free(temp);
}

int main() {
    int nums[] = {5, 2, 6, 1};
    int n = sizeof(nums) / sizeof(nums[0]);

    int result[n];

    countSmaller(nums, n, result);

    for (int i = 0; i < n; i++) {
        printf("%d ", result[i]);
    }

    return 0;
}
